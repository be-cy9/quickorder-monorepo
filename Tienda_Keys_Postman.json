{
  "info": {
    "name": "QuickOrder - Game Keys Store (COMPLETO)",
    "description": "Colección completa de todos los microservicios de QuickOrder. Incluye autenticación JWT automática, variables de entorno y casos de error. Usar con el entorno 'QuickOrder Local'.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "description": "URL del API Gateway (puerto 8080)"
    },
    {
      "key": "token",
      "value": "",
      "description": "JWT Token - se llena automáticamente al hacer login"
    }
  ],
  "item": [
    {
      "name": "0. Autenticación JWT",
      "item": [
        {
          "name": "Login (obtener token JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "// El token viene en el campo 'respuestaText'",
                  "if (jsonData.respuestaText && jsonData.respuestaInteger === 0) {",
                  "    pm.collectionVariables.set('token', jsonData.respuestaText);",
                  "    console.log('✅ Token JWT guardado correctamente');",
                  "} else {",
                  "    console.log('❌ Login fallido: ' + jsonData.respuestaText);",
                  "}",
                  "pm.test('Login exitoso - Status 200', function() {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Respuesta contiene token JWT', function() {",
                  "    pm.expect(jsonData.respuestaText).to.exist;",
                  "    pm.expect(jsonData.respuestaInteger).to.equal(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Hacer login con admin/1234. El token JWT se guarda automáticamente en {{token}}. La respuesta tiene el token en el campo 'respuestaText'."
          }
        },
        {
          "name": "Login - Error: credenciales inválidas (401)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.test('Credenciales inválidas retornan código de error', function() {",
                  "    pm.expect(jsonData.respuestaInteger).to.equal(2);",
                  "});",
                  "pm.test('Mensaje de error presente', function() {",
                  "    pm.expect(jsonData.respuestaText).to.include('inválidas');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"usuario_falso\",\n  \"password\": \"password_incorrecto\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Debe retornar respuestaInteger=2 (UNAUTHORIZED) con credenciales incorrectas."
          }
        }
      ]
    },
